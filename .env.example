# Docker Compose environment variables for Mopidy-Mp3Quran

# Path to your local music library (optional)
# If not set, defaults to $HOME/Music
MUSIC_DIR=/path/to/your/music

# Path to custom Mopidy configuration file (optional)
# If not set, uses the default config from docker/mopidy.conf
MOPIDY_CONFIG=./docker/mopidy.conf
